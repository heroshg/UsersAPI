{
  "ConnectionStrings": {
    "Users": "Host=<rds-fcg-dev-users-endpoint>;Port=5432;Database=users_db;Username=postgres;Password="
  },
  "Jwt": {
    "RsaPublicKey": "<base64 do PEM da chave pública — ver README para gerar o par RSA>",
    "RsaPrivateKey": "<base64 do PEM da chave privada — só a UsersAPI precisa dela>",
    "Issuer": "FiapCloudGames",
    "Audience": "FiapCloudGames",
    "ExpirationMinutes": 15
  },
  "AWS": {
    "Region": "us-east-1"
  },
  "Messaging": {
    "Scope": "fcg-dev"
  },
  "Redis": {
    "ConnectionString": ""
  }
}
